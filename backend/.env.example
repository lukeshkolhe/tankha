# Postgres connection string (Prisma). Local dev shown below; a hosted
# provider like Neon gives you a string of the form
# "postgresql://user:pass@host/db?sslmode=require" — use that as-is in production.
DATABASE_URL="postgresql://tankha:tankha@localhost:5432/tankha?schema=public"

# Prisma Migrate needs a direct (non-pooled) connection. Neon gives you two
# connection strings — a pooled one (use for DATABASE_URL) and a direct one
# (use here). Same value as DATABASE_URL for local dev or any non-pooled provider.
DIRECT_DATABASE_URL="postgresql://tankha:tankha@localhost:5432/tankha?schema=public"

# JWT signing secret (HS256) — use a long random value in production
JWT_SECRET="dev-only-change-me-in-production-please"
JWT_EXPIRES_IN="24h"

# API
PORT=3000

# Comma-separated browser origins allowed via CORS. Defaults to the Vite dev
# server (http://localhost:5173) if unset — only needed in production, where
# frontend and backend are on different domains.
# CORS_ORIGINS="https://tankha.vercel.app"
